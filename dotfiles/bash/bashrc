# Portable interactive Bash configuration.

dotfiles_generated=${XDG_CONFIG_HOME:-"$HOME/.config"}/dotfiles/generated.sh
if [ -r "$dotfiles_generated" ]; then
    # shellcheck disable=SC1090
    . "$dotfiles_generated"
fi
unset dotfiles_generated

if [ -n "${DOTFILES_ROOT:-}" ] && [ -r "$DOTFILES_ROOT/dotfiles/shell/env.sh" ]; then
    # shellcheck disable=SC1090
    . "$DOTFILES_ROOT/dotfiles/shell/env.sh"
fi

case $- in *i*) ;; *) return ;; esac

dotfiles_bash_state=${XDG_STATE_HOME:-"$HOME/.local/state"}/bash
dotfiles_bash_history=$dotfiles_bash_state/history
dotfiles_bash_legacy_history=$HOME/.bash_history
if mkdir -p "$dotfiles_bash_state" 2>/dev/null; then
    chmod 700 "$dotfiles_bash_state" 2>/dev/null || true
    if [ ! -e "$dotfiles_bash_history" ]; then
        if [ -f "$dotfiles_bash_legacy_history" ]; then
            cp -p "$dotfiles_bash_legacy_history" "$dotfiles_bash_history" 2>/dev/null || true
        else
            : > "$dotfiles_bash_history" 2>/dev/null || true
        fi
    fi
fi
if [ -f "$dotfiles_bash_history" ] && [ -w "$dotfiles_bash_history" ]; then
    HISTFILE=$dotfiles_bash_history
    chmod 600 "$HISTFILE" 2>/dev/null || true
else
    HISTFILE=$dotfiles_bash_legacy_history
    printf 'warning: cannot use XDG Bash history; falling back to %s\n' "$HISTFILE" >&2
fi
unset dotfiles_bash_state dotfiles_bash_history dotfiles_bash_legacy_history
HISTSIZE=50000
HISTFILESIZE=50000
HISTCONTROL=ignoreboth:erasedups
shopt -s histappend checkwinsize cmdhist
# Bash reads its default history before .bashrc. After moving HISTFILE to the
# XDG state directory, replace that initial list with the selected file so a
# new shell sees commands saved by the previous shell.
history -c
history -r "$HISTFILE" 2>/dev/null || true

if [ -r /usr/share/bash-completion/bash_completion ]; then
    # shellcheck disable=SC1091
    . /usr/share/bash-completion/bash_completion
elif [ -r /opt/homebrew/etc/profile.d/bash_completion.sh ]; then
    # shellcheck disable=SC1091
    . /opt/homebrew/etc/profile.d/bash_completion.sh
fi

if [ -t 1 ]; then
    PS1='\[\033[0;36m\]\u@\h\[\033[0m\]:\[\033[0;34m\]\w\[\033[0m\] \$ '
fi

if [ -n "${DOTFILES_CONDA_EXE:-}" ] && [ -f "$DOTFILES_CONDA_EXE" ]; then
    conda() {
        local dotfiles_conda_hook
        dotfiles_conda_hook=$("$DOTFILES_CONDA_EXE" shell.bash hook 2>/dev/null) || {
            "$DOTFILES_CONDA_EXE" "$@"
            return $?
        }
        unset -f conda
        eval "$dotfiles_conda_hook"
        unset dotfiles_conda_hook
        conda "$@"
    }
fi

if [ -n "${DOTFILES_ROOT:-}" ] && [ -r "$DOTFILES_ROOT/dotfiles/shell/interactive.sh" ]; then
    # shellcheck disable=SC1090
    . "$DOTFILES_ROOT/dotfiles/shell/interactive.sh"
fi

dotfiles_local_bash=${XDG_CONFIG_HOME:-"$HOME/.config"}/dotfiles/local.bash
if [ -r "$dotfiles_local_bash" ]; then
    # shellcheck disable=SC1090
    . "$dotfiles_local_bash"
fi
unset dotfiles_local_bash

if command -v dotfiles_load_nvm >/dev/null 2>&1; then
    dotfiles_load_nvm
fi
