#!/usr/bin/env bash
# A dependency-free dotfiles manager. Compatible with Bash 3.2+.

set -u

PROGRAM=${0##*/}
DRY_RUN=0
BACKUP_DIR=""
TRANSACTION_ACTIVE=0
TRANSACTION_DIR=""
TRANSACTION_ORIGINAL_HEAD=""
TRANSACTION_HOME_LIST=""
TRANSACTION_PUSHING=0
TRANSACTION_BUILDING=0
TRANSACTION_COMMITTED=0
TRANSACTION_LOCK=""
TRANSACTION_LOCK_HELD=0
TRANSACTION_BACKUP_DIR=""
TRANSACTION_CHECKPOINT=0
TRANSACTION_EXPECTED_FILE=""
SYNC_REMOTE=""
SYNC_MERGE_REF=""
SYNC_UPSTREAM_REF=""

log() {
    printf '%s\n' "$*"
}

warn() {
    printf 'warning: %s\n' "$*" >&2
}

die() {
    printf 'error: %s\n' "$*" >&2
    exit 1
}

resolve_script_root() {
    local source_path dir_path link_path
    source_path=$0
    case "$source_path" in
        /*) ;;
        *) source_path=$PWD/$source_path ;;
    esac

    while [ -L "$source_path" ]; do
        dir_path=$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd) || exit 1
        link_path=$(readlink "$source_path") || exit 1
        case "$link_path" in
            /*) source_path=$link_path ;;
            *) source_path=$dir_path/$link_path ;;
        esac
    done
    dir_path=$(cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd) || exit 1
    (cd "$dir_path/.." >/dev/null 2>&1 && pwd)
}

: "${HOME:?HOME must be set}"
XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-"$HOME/.config"}
XDG_STATE_HOME=${XDG_STATE_HOME:-"$HOME/.local/state"}
TRANSACTION_LOCK=$XDG_STATE_HOME/dotfiles/transaction.lock
CONFIG_DIR=$XDG_CONFIG_HOME/dotfiles
ROOT_HINT=$CONFIG_DIR/root
DERIVED_ROOT=$(resolve_script_root)

if [ -f "$DERIVED_ROOT/.dotfiles-manifest" ]; then
    # A command run directly from a repository must win over exported state or
    # a stale hint from another clone. A copied command has no manifest beside
    # it and falls back.
    ROOT=$DERIVED_ROOT
elif [ -r "$ROOT_HINT" ]; then
    IFS= read -r ROOT < "$ROOT_HINT"
    if [ ! -f "$ROOT/.dotfiles-manifest" ]; then
        if [ -n "${DOTFILES_ROOT:-}" ] && [ -f "$DOTFILES_ROOT/.dotfiles-manifest" ]; then
            ROOT=$DOTFILES_ROOT
        else
            ROOT=$DERIVED_ROOT
        fi
    fi
elif [ -n "${DOTFILES_ROOT:-}" ] && [ -f "$DOTFILES_ROOT/.dotfiles-manifest" ]; then
    ROOT=$DOTFILES_ROOT
else
    ROOT=$DERIVED_ROOT
fi

MANIFEST=$ROOT/.dotfiles-manifest
[ -f "$MANIFEST" ] || die "cannot find .dotfiles-manifest; set DOTFILES_ROOT to the repository"

DEVICE_CONFIG=$CONFIG_DIR/device.conf
DOTFILES_DEVICE_CONDA_ROOT=${DOTFILES_DEVICE_CONDA_ROOT:-}
DOTFILES_INSTALL_MODE=${DOTFILES_INSTALL_MODE:-auto}
if [ -r "$DEVICE_CONFIG" ]; then
    # This file is deliberately local to the device and owned by the user.
    # shellcheck disable=SC1090
    . "$DEVICE_CONFIG"
fi

detect_os() {
    local kernel
    kernel=$(uname -s 2>/dev/null || printf unknown)
    case "$kernel" in
        Darwin) printf 'macos\n' ;;
        Linux)
            if [ -r /proc/version ] && grep -qi microsoft /proc/version 2>/dev/null; then
                printf 'wsl\n'
            else
                printf 'linux\n'
            fi
            ;;
        MINGW*|MSYS*|CYGWIN*) printf 'windows\n' ;;
        *) printf 'unknown\n' ;;
    esac
}

OS=$(detect_os)
HOST_NAME=$(hostname 2>/dev/null || uname -n 2>/dev/null || printf unknown)
HOST_NAME=${HOST_NAME%%.*}

scope_applies() {
    local scope item old_ifs
    scope=$1
    old_ifs=$IFS
    IFS=,
    for item in $scope; do
        case "$item" in
            all) IFS=$old_ifs; return 0 ;;
            unix)
                case "$OS" in macos|linux|wsl) IFS=$old_ifs; return 0 ;; esac
                ;;
            "$OS") IFS=$old_ifs; return 0 ;;
        esac
    done
    IFS=$old_ifs
    return 1
}

validate_relative_path() {
    case "$1" in
        ""|/*|..|../*|*/../*|*/..) die "unsafe manifest target: $1" ;;
    esac
}

resolved_mode() {
    local requested
    requested=${1:-$DOTFILES_INSTALL_MODE}
    case "$requested" in
        auto)
            if [ "$OS" = windows ]; then
                printf 'copy\n'
            else
                printf 'link\n'
            fi
            ;;
        link|copy) printf '%s\n' "$requested" ;;
        *) die "install mode must be auto, link, or copy" ;;
    esac
}

shell_quote() {
    local escaped
    escaped=$(printf '%s' "$1" | sed "s/'/'\\\\''/g")
    printf "'%s'" "$escaped"
}

make_dir() {
    if [ -d "$1" ]; then
        return
    fi
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] mkdir -p $1"
    else
        mkdir -p "$1" || die "cannot create directory: $1"
    fi
}

write_root_hint() {
    local tmp
    make_dir "$CONFIG_DIR"
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] write $ROOT_HINT"
        return
    fi
    tmp=$ROOT_HINT.tmp.$$
    if ! printf '%s\n' "$ROOT" > "$tmp"; then
        rm -f "$tmp"
        die "cannot write $tmp"
    fi
    if ! mv "$tmp" "$ROOT_HINT"; then
        rm -f "$tmp"
        die "cannot install $ROOT_HINT"
    fi
}

conda_from_root() {
    local candidate_root conda_candidate
    candidate_root=$1
    [ -n "$candidate_root" ] || return 1
    for conda_candidate in \
        "$candidate_root/bin/conda" \
        "$candidate_root/condabin/conda" \
        "$candidate_root/Scripts/conda.exe" \
        "$candidate_root/Scripts/conda"; do
        if [ -x "$conda_candidate" ] || [ -f "$conda_candidate" ]; then
            printf '%s\n' "$conda_candidate"
            return 0
        fi
    done
    return 1
}

detect_conda() {
    local executable base candidate
    if [ -n "$DOTFILES_DEVICE_CONDA_ROOT" ]; then
        conda_from_root "$DOTFILES_DEVICE_CONDA_ROOT"
        return $?
    fi
    if [ -n "${CONDA_EXE:-}" ] && { [ -x "$CONDA_EXE" ] || [ -f "$CONDA_EXE" ]; }; then
        printf '%s\n' "$CONDA_EXE"
        return 0
    fi
    executable=$(command -v conda 2>/dev/null || true)
    if [ -n "$executable" ] && { [ -x "$executable" ] || [ -f "$executable" ]; }; then
        printf '%s\n' "$executable"
        return 0
    fi
    for base in \
        "$HOME/miniconda3" \
        "$HOME/anaconda3" \
        "$HOME/miniforge3" \
        "$HOME/mambaforge" \
        "/opt/homebrew/Caskroom/miniconda/base" \
        "/usr/local/Caskroom/miniconda/base"; do
        candidate=$(conda_from_root "$base" 2>/dev/null || true)
        if [ -n "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

conda_root_from_exe() {
    local parent
    parent=$(dirname "$1")
    case "${parent##*/}" in
        bin|condabin|Scripts) dirname "$parent" ;;
        *) printf '%s\n' "$parent" ;;
    esac
}

write_generated_env() {
    local generated tmp conda_exe conda_root
    generated=$CONFIG_DIR/generated.sh
    make_dir "$CONFIG_DIR"
    conda_exe=$(detect_conda 2>/dev/null || true)
    conda_root=""
    if [ -n "$conda_exe" ]; then
        conda_root=$(conda_root_from_exe "$conda_exe")
    elif [ -n "$DOTFILES_DEVICE_CONDA_ROOT" ]; then
        warn "configured Conda root has no conda executable: $DOTFILES_DEVICE_CONDA_ROOT"
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] generate $generated (os=$OS, host=$HOST_NAME)"
        return
    fi

    tmp=$generated.tmp.$$
    if ! {
        printf '# Generated by dotfiles install. Do not edit.\n'
        printf 'export DOTFILES_ROOT=%s\n' "$(shell_quote "$ROOT")"
        printf 'export DOTFILES_OS=%s\n' "$(shell_quote "$OS")"
        printf 'export DOTFILES_HOST=%s\n' "$(shell_quote "$HOST_NAME")"
        if [ -n "$conda_exe" ]; then
            printf 'export DOTFILES_CONDA_EXE=%s\n' "$(shell_quote "$conda_exe")"
            printf 'export DOTFILES_CONDA_ROOT=%s\n' "$(shell_quote "$conda_root")"
        else
            printf 'unset DOTFILES_CONDA_EXE DOTFILES_CONDA_ROOT\n'
        fi
    } > "$tmp"; then
        rm -f "$tmp"
        die "cannot write $tmp"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    if ! mv "$tmp" "$generated"; then
        rm -f "$tmp"
        die "cannot install $generated"
    fi
}

ensure_local_file() {
    local source_file target_file
    source_file=$1
    target_file=$2
    if [ -e "$target_file" ] || [ -L "$target_file" ]; then
        return
    fi
    make_dir "$(dirname "$target_file")"
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] create local config $target_file"
    else
        cp "$source_file" "$target_file" || die "cannot create $target_file"
        chmod 600 "$target_file" 2>/dev/null || true
        log "created local config: $target_file"
    fi
}

is_managed_shell_link() {
    local target_path managed_rel link_path candidate_root
    target_path=$1
    managed_rel=$2
    [ -L "$target_path" ] || return 1
    link_path=$(readlink "$target_path" 2>/dev/null || true)
    case "$link_path" in
        "$ROOT/$managed_rel") return 0 ;;
        */"$managed_rel")
            candidate_root=${link_path%"/$managed_rel"}
            [ -f "$candidate_root/.dotfiles-manifest" ]
            return $?
            ;;
    esac
    return 1
}

preserve_shell_wrapper_content() {
    local target_path managed_source preserved_path relative_target base_source
    local reference_source reference_lines prefix_path first_extra_line
    target_path=$1
    managed_source=$2
    preserved_path=$3
    : > "$preserved_path" || die "cannot prepare local shell content"

    if [ -L "$target_path" ]; then
        cp -pL "$target_path" "$preserved_path" 2>/dev/null || true
        return
    fi
    if [ ! -f "$target_path" ]; then
        return
    fi

    relative_target=${target_path#"$HOME"/}
    base_source=$(copy_base_path "$relative_target")
    for reference_source in "$managed_source" "$base_source"; do
        [ -f "$reference_source" ] || continue
        if cmp -s "$reference_source" "$target_path"; then
            return
        fi
        reference_lines=$(wc -l < "$reference_source" | tr -d ' ')
        [ "$reference_lines" -gt 0 ] || continue
        prefix_path=$preserved_path.prefix
        sed -n "1,${reference_lines}p" "$target_path" > "$prefix_path" \
            || die "cannot inspect existing shell entry point"
        if cmp -s "$reference_source" "$prefix_path"; then
            first_extra_line=$((reference_lines + 1))
            sed -n "${first_extra_line},\$p" "$target_path" > "$preserved_path" \
                || die "cannot preserve local shell additions"
            rm -f "$prefix_path"
            return
        fi
        rm -f "$prefix_path"
    done
    cp -p "$target_path" "$preserved_path" \
        || die "cannot preserve existing shell entry point"
}

preserve_existing_wrapper_suffix() {
    local target_path preserved_path end_line first_extra_line
    target_path=$1
    preserved_path=$2
    : > "$preserved_path" || die "cannot prepare shell wrapper suffix"
    end_line=$(awk '/^# dotfiles-local-wrapper-end:/ { print NR; exit }' "$target_path")
    [ -n "$end_line" ] || return 0
    first_extra_line=$((end_line + 1))
    sed -n "${first_extra_line},\$p" "$target_path" > "$preserved_path" \
        || die "cannot preserve third-party shell additions"
}

backup_managed_shell_content() {
    local target_path relative link_backup content_backup
    target_path=$1
    relative=${target_path#"$HOME"/}
    link_backup=$BACKUP_DIR/$relative
    content_backup=$link_backup.managed-content
    if [ -L "$link_backup" ] && [ -f "$link_backup" ]; then
        cp -pL "$link_backup" "$content_backup" \
            || die "cannot snapshot managed shell content: $target_path"
        chmod 600 "$content_backup" 2>/dev/null || true
        log "backed up linked shell content: $content_backup"
    fi
}

ensure_shell_wrapper() {
    local template_path target_path managed_rel managed_source first_line expected_marker
    local preserved_path managed_link existing_wrapper
    template_path=$1
    target_path=$2
    managed_rel=$3
    managed_source=$ROOT/$managed_rel
    [ -f "$template_path" ] || die "shell wrapper template does not exist: $template_path"
    [ -f "$managed_source" ] || die "shared shell source does not exist: $managed_source"
    IFS= read -r expected_marker < "$template_path" || expected_marker=""
    case "$expected_marker" in
        '# dotfiles-local-wrapper:'*) ;;
        *) die "invalid shell wrapper template marker: $template_path" ;;
    esac

    existing_wrapper=0
    if [ -f "$target_path" ] && [ ! -L "$target_path" ]; then
        IFS= read -r first_line < "$target_path" || first_line=""
        if [ "$first_line" = "$expected_marker" ]; then
            return
        fi
        case "$first_line" in '# dotfiles-local-wrapper:'*) existing_wrapper=1 ;; esac
    fi
    if [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
        if [ "$DRY_RUN" -eq 1 ]; then
            log "[dry-run] create local shell wrapper $target_path"
            return
        fi
        cp "$template_path" "$target_path" || die "cannot create $target_path"
        chmod 600 "$target_path" 2>/dev/null || true
        log "created local shell wrapper: $target_path"
        return
    fi

    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] migrate local shell entry point $target_path"
        return
    fi
    preserved_path=$XDG_STATE_HOME/dotfiles/wrapper-preserved.$$
    managed_link=0
    if is_managed_shell_link "$target_path" "$managed_rel"; then
        managed_link=1
        : > "$preserved_path" || die "cannot prepare shell wrapper migration"
    elif [ "$existing_wrapper" -eq 1 ]; then
        preserve_existing_wrapper_suffix "$target_path" "$preserved_path"
    else
        preserve_shell_wrapper_content "$target_path" "$managed_source" "$preserved_path"
    fi
    backup_target "$target_path"
    if [ "$managed_link" -eq 1 ]; then
        backup_managed_shell_content "$target_path"
    fi
    cp "$template_path" "$target_path" || die "cannot create $target_path"
    chmod 600 "$target_path" 2>/dev/null || true
    if [ -s "$preserved_path" ]; then
        {
            printf '\n# Preserved local content from before dotfiles wrapper migration.\n'
            cat "$preserved_path"
        } >> "$target_path" || die "cannot restore local shell content"
    fi
    rm -f "$preserved_path" || true
    log "migrated local shell wrapper: $target_path"
}

ensure_runtime_files() {
    make_dir "$XDG_STATE_HOME/dotfiles/backups"
    make_dir "$XDG_STATE_HOME/bash"
    make_dir "$XDG_STATE_HOME/zsh"
    make_dir "$XDG_STATE_HOME/vim/backup"
    make_dir "$XDG_STATE_HOME/vim/swap"
    make_dir "$XDG_STATE_HOME/vim/undo"
    make_dir "$HOME/.ssh/config.d"
    if [ "$DRY_RUN" -eq 0 ]; then
        chmod 700 "$HOME/.ssh" "$HOME/.ssh/config.d" 2>/dev/null || true
    fi
    ensure_shell_wrapper "$ROOT/examples/shell-wrappers/bashrc" \
        "$HOME/.bashrc" dotfiles/bash/bashrc
    ensure_shell_wrapper "$ROOT/examples/shell-wrappers/bash_profile" \
        "$HOME/.bash_profile" dotfiles/bash/bash_profile
    ensure_shell_wrapper "$ROOT/examples/shell-wrappers/profile" \
        "$HOME/.profile" dotfiles/shell/profile
    ensure_shell_wrapper "$ROOT/examples/shell-wrappers/zprofile" \
        "$HOME/.zprofile" dotfiles/zsh/zprofile
    ensure_shell_wrapper "$ROOT/examples/shell-wrappers/zshrc" \
        "$HOME/.zshrc" dotfiles/zsh/zshrc
    ensure_local_file "$ROOT/examples/local.zsh" "$CONFIG_DIR/local.zsh"
    ensure_local_file "$ROOT/examples/local.bash" "$CONFIG_DIR/local.bash"
    ensure_local_file "$ROOT/examples/local.profile" "$CONFIG_DIR/local.profile"
    ensure_local_file "$ROOT/examples/git-local.conf" "$XDG_CONFIG_HOME/git/local.conf"
    ensure_local_file "$ROOT/examples/ssh-config.local" "$HOME/.ssh/config.local"
}

backup_target() {
    local target relative backup_target
    target=$1
    relative=${target#"$HOME"/}
    if [ -z "$BACKUP_DIR" ]; then
        if [ "$TRANSACTION_ACTIVE" -eq 1 ] && [ -n "$TRANSACTION_BACKUP_DIR" ]; then
            BACKUP_DIR=$TRANSACTION_BACKUP_DIR
        else
            BACKUP_DIR=$XDG_STATE_HOME/dotfiles/backups/$(date +%Y%m%d-%H%M%S)-$$
        fi
    fi
    backup_target=$BACKUP_DIR/$relative
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] backup $target -> $backup_target"
        return
    fi
    mkdir -p "$(dirname "$backup_target")" || die "cannot create backup directory"
    mv "$target" "$backup_target" || die "cannot back up $target"
    log "backed up: $target -> $backup_target"
}

copy_base_path() {
    printf '%s\n' "$XDG_STATE_HOME/dotfiles/copy-base/$1"
}

record_copy_base() {
    local source_path relative_target base_path
    source_path=$1
    relative_target=$2
    base_path=$(copy_base_path "$relative_target")
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] record copy baseline for $relative_target"
        return
    fi
    mkdir -p "$(dirname "$base_path")" || die "cannot create copy baseline directory"
    cp -p "$source_path" "$base_path" || die "cannot record copy baseline: $relative_target"
}

install_one() {
    local source_path relative_target target_path mode current_link
    source_path=$1
    relative_target=$2
    mode=$3
    validate_relative_path "$relative_target"
    target_path=$HOME/$relative_target
    [ -e "$source_path" ] || die "manifest source does not exist: $source_path"

    if [ "$mode" = link ] && [ -L "$target_path" ]; then
        current_link=$(readlink "$target_path" 2>/dev/null || true)
        if [ "$current_link" = "$source_path" ]; then
            log "ok: $relative_target"
            return
        fi
    elif [ "$mode" = copy ] && [ ! -L "$target_path" ] && [ -f "$target_path" ] && cmp -s "$source_path" "$target_path"; then
        record_copy_base "$source_path" "$relative_target"
        log "ok: $relative_target"
        return
    fi

    if [ -e "$target_path" ] || [ -L "$target_path" ]; then
        backup_target "$target_path"
    fi
    make_dir "$(dirname "$target_path")"
    if [ "$DRY_RUN" -eq 1 ]; then
        log "[dry-run] $mode $relative_target"
    elif [ "$mode" = link ]; then
        ln -s "$source_path" "$target_path" || die "cannot link $target_path"
        log "linked: $relative_target"
    else
        cp -p "$source_path" "$target_path" || die "cannot copy $target_path"
        record_copy_base "$source_path" "$relative_target"
        log "copied: $relative_target"
    fi
}

install_all() {
    local mode scope source_rel target_rel
    mode=$1
    log "Installing for $OS on $HOST_NAME (mode: $mode)"
    write_root_hint
    write_generated_env
    ensure_runtime_files
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        install_one "$ROOT/$source_rel" "$target_rel" "$mode"
    done < "$MANIFEST"
    if [ -n "$BACKUP_DIR" ]; then
        log "Backup directory: $BACKUP_DIR"
    fi
    if [ "$TRANSACTION_ACTIVE" -eq 1 ]; then
        log "Deployment validated; waiting for transaction commit."
    else
        log "Done. Start a new shell or run: exec \"${SHELL:-zsh}\" -l"
    fi
}

status_shell_wrapper() {
    local target_path expected_marker first_line
    target_path=$1
    expected_marker=$2
    if [ -f "$target_path" ] && [ ! -L "$target_path" ]; then
        IFS= read -r first_line < "$target_path" || first_line=""
        if [ "$first_line" = "$expected_marker" ]; then
            printf '[local]   %s\n' "${target_path#"$HOME"/}"
            return 0
        fi
    elif [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
        printf '[missing] %s (local shell wrapper)\n' "${target_path#"$HOME"/}"
        return 1
    fi
    printf '[drift]   %s (expected a local shell wrapper)\n' "${target_path#"$HOME"/}"
    return 1
}

status_all() {
    local mode scope source_rel target_rel source_path target_path current_link failures
    mode=$(resolved_mode "${1:-}")
    failures=0
    log "Platform: $OS; expected mode: $mode; repository: $ROOT"
    status_shell_wrapper "$HOME/.bashrc" '# dotfiles-local-wrapper:v1:bashrc' \
        || failures=$((failures + 1))
    status_shell_wrapper "$HOME/.bash_profile" '# dotfiles-local-wrapper:v1:bash-profile' \
        || failures=$((failures + 1))
    status_shell_wrapper "$HOME/.profile" '# dotfiles-local-wrapper:v1:profile' \
        || failures=$((failures + 1))
    status_shell_wrapper "$HOME/.zshrc" '# dotfiles-local-wrapper:v1:zshrc' \
        || failures=$((failures + 1))
    status_shell_wrapper "$HOME/.zprofile" '# dotfiles-local-wrapper:v1:zprofile' \
        || failures=$((failures + 1))
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        source_path=$ROOT/$source_rel
        target_path=$HOME/$target_rel
        if [ ! -e "$source_path" ]; then
            printf '[source-missing] %s <- %s\n' "$target_rel" "$source_rel"
            failures=$((failures + 1))
        elif [ "$mode" = link ] && [ -L "$target_path" ]; then
            current_link=$(readlink "$target_path" 2>/dev/null || true)
            if [ "$current_link" = "$source_path" ]; then
                printf '[ok]      %s\n' "$target_rel"
            else
                printf '[drift]   %s -> %s\n' "$target_rel" "$current_link"
                failures=$((failures + 1))
            fi
        elif [ "$mode" = copy ] && [ ! -L "$target_path" ] && [ -f "$target_path" ] && cmp -s "$source_path" "$target_path"; then
            printf '[ok]      %s\n' "$target_rel"
        elif [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
            printf '[missing] %s\n' "$target_rel"
            failures=$((failures + 1))
        else
            printf '[drift]   %s\n' "$target_rel"
            failures=$((failures + 1))
        fi
    done < "$MANIFEST"
    return "$failures"
}

uninstall_all() {
    local mode scope source_rel target_rel source_path target_path current_link base_path removed kept
    mode=$(resolved_mode "${1:-}")
    removed=0
    kept=0
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        source_path=$ROOT/$source_rel
        target_path=$HOME/$target_rel
        current_link=""
        if [ -L "$target_path" ]; then
            current_link=$(readlink "$target_path" 2>/dev/null || true)
        fi
        if { [ "$mode" = link ] && [ "$current_link" = "$source_path" ]; } || \
           { [ "$mode" = copy ] && [ ! -L "$target_path" ] && [ -f "$target_path" ] && cmp -s "$source_path" "$target_path"; }; then
            if [ "$DRY_RUN" -eq 1 ]; then
                log "[dry-run] remove $target_path"
            else
                rm "$target_path" || die "cannot remove $target_path"
                if [ "$mode" = copy ]; then
                    base_path=$(copy_base_path "$target_rel")
                    if [ -f "$base_path" ]; then
                        rm "$base_path" || die "cannot remove copy baseline: $base_path"
                    fi
                fi
                log "removed: $target_rel"
            fi
            removed=$((removed + 1))
        elif [ -e "$target_path" ] || [ -L "$target_path" ]; then
            warn "kept modified or unmanaged file: $target_path"
            kept=$((kept + 1))
        fi
    done < "$MANIFEST"
    log "Removed $removed managed files; kept $kept modified/unmanaged files."
    log "Device-local files and backups were not removed."
}

preflight_copy_capture() {
    local scope source_rel target_rel source_path target_path base_path source_changed target_changed
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        source_path=$ROOT/$source_rel
        target_path=$HOME/$target_rel
        base_path=$(copy_base_path "$target_rel")
        [ -f "$source_path" ] || die "manifest source is missing: $source_rel"
        if [ -L "$target_path" ] || [ ! -f "$target_path" ]; then
            die "copy-mode target is missing or not a regular file: $target_rel; run dotfiles install --mode copy"
        fi
        if [ ! -f "$base_path" ]; then
            if cmp -s "$source_path" "$target_path"; then
                record_copy_base "$source_path" "$target_rel"
            else
                die "cannot determine which copy is newer: $target_rel; reconcile it manually, then run install --mode copy"
            fi
        fi
        source_changed=0
        target_changed=0
        cmp -s "$source_path" "$base_path" || source_changed=1
        cmp -s "$target_path" "$base_path" || target_changed=1
        if [ "$source_changed" -eq 1 ] && [ "$target_changed" -eq 1 ] && ! cmp -s "$source_path" "$target_path"; then
            die "copy conflict: both repository and HOME changed $target_rel"
        fi
    done < "$MANIFEST"
}

capture_copy_changes() {
    local scope source_rel target_rel source_path target_path base_path captured
    captured=0
    preflight_copy_capture
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        source_path=$ROOT/$source_rel
        target_path=$HOME/$target_rel
        base_path=$(copy_base_path "$target_rel")
        if ! cmp -s "$target_path" "$base_path" && cmp -s "$source_path" "$base_path"; then
            cp -p "$target_path" "$source_path" || die "cannot capture $target_rel"
            log "captured: $target_rel"
            captured=$((captured + 1))
        fi
    done < "$MANIFEST"
    log "Captured $captured changed HOME copies."
}

check_staged_secrets() {
    local staged_list staged_file base_name suspicious
    staged_list=$XDG_STATE_HOME/dotfiles/staged-files.$$
    mkdir -p "$(dirname "$staged_list")" || die "cannot create dotfiles state directory"
    git -C "$ROOT" diff --cached --name-only --diff-filter=ACMR > "$staged_list" \
        || die "cannot inspect staged files"
    suspicious=""
    while IFS= read -r staged_file; do
        [ -n "$staged_file" ] || continue
        base_name=${staged_file##*/}
        case "$base_name" in
            id_rsa*|id_dsa*|id_ecdsa*|id_ed25519*|*.pem|*.key|.env|.env.*)
                suspicious=$staged_file
                break
                ;;
        esac
        if git -C "$ROOT" show ":$staged_file" 2>/dev/null | \
            grep -Eq -- 'BEGIN ([A-Z0-9]+ )?PRIVATE KEY|AKIA[0-9A-Z]{16}|gh[pousr]_[A-Za-z0-9_]{20,}|sk-[A-Za-z0-9_-]{20,}|glpat-[A-Za-z0-9_-]{20,}|xox[baprs]-[A-Za-z0-9-]{20,}'; then
            suspicious=$staged_file
            break
        fi
    done < "$staged_list"
    rm "$staged_list" || true
    [ -z "$suspicious" ] || die "refusing to commit a possible secret: $suspicious"
}

managed_repository_path() {
    case "$1" in
        .dotfiles-manifest|.gitattributes|.gitignore|README.md) return 0 ;;
        bin|bin/*|dotfiles|dotfiles/*|examples|examples/*|profiles|profiles/*|tests|tests/*) return 0 ;;
        *) return 1 ;;
    esac
}

check_repository_scope() {
    local changed_list changed_path outside_path
    changed_list=$XDG_STATE_HOME/dotfiles/preflight-files.$$
    mkdir -p "$(dirname "$changed_list")" || die "cannot create dotfiles state directory"
    {
        git -C "$ROOT" diff --name-only --no-renames HEAD
        git -C "$ROOT" ls-files --others --exclude-standard
    } > "$changed_list" || die "cannot inspect repository changes"
    outside_path=""
    while IFS= read -r changed_path; do
        [ -n "$changed_path" ] || continue
        if ! managed_repository_path "$changed_path"; then
            outside_path=$changed_path
            break
        fi
    done < "$changed_list"
    rm "$changed_list" || true
    [ -z "$outside_path" ] || die "uncommitted path is outside the dotfiles transaction: $outside_path"
}

preflight_local_transaction() {
    command -v git >/dev/null 2>&1 || die "git is required for transactional changes"
    git -C "$ROOT" rev-parse --verify HEAD >/dev/null 2>&1 \
        || die "transaction requires a repository with at least one commit"
    git -C "$ROOT" diff --cached --quiet \
        || die "repository already has staged changes; commit or unstage them first"
    check_repository_scope
}

transaction_repository_paths() {
    printf '%s\n' \
        .dotfiles-manifest .gitattributes .gitignore README.md \
        bin dotfiles examples profiles tests
}

find_pending_transactions() {
    local transaction_base candidate
    transaction_base=$XDG_STATE_HOME/dotfiles/transactions
    for candidate in "$transaction_base"/*; do
        if [ -f "$candidate/ACTIVE" ] || [ -f "$candidate/IN_DOUBT" ]; then
            printf '%s\n' "$candidate"
        fi
    done
}

assert_no_pending_transaction() {
    local pending
    pending=$(find_pending_transactions | sed -n '1p')
    [ -z "$pending" ] \
        || die "an unresolved dotfiles transaction exists; run 'dotfiles recover': $pending"
}

path_mode() {
    stat -c '%a' "$1" 2>/dev/null || stat -f '%Lp' "$1" 2>/dev/null
}

fingerprint_path() {
    local path label mode checksum link_target
    path=$1
    label=$2
    if [ -L "$path" ]; then
        mode=$(path_mode "$path") || return 1
        link_target=$(readlink "$path") || return 1
        printf 'L|%s|%s|%s\n' "$label" "$mode" "$link_target"
    elif [ -f "$path" ]; then
        mode=$(path_mode "$path") || return 1
        checksum=$(cksum < "$path") || return 1
        printf 'F|%s|%s|%s\n' "$label" "$mode" "$checksum"
    elif [ -d "$path" ]; then
        mode=$(path_mode "$path") || return 1
        printf 'D|%s|%s\n' "$label" "$mode"
    elif [ -e "$path" ]; then
        mode=$(path_mode "$path") || return 1
        printf 'O|%s|%s\n' "$label" "$mode"
    else
        printf 'A|%s\n' "$label"
    fi
}

fingerprint_tree() {
    local tree_path label path_list item relative
    tree_path=$1
    label=$2
    fingerprint_path "$tree_path" "$label" || return 1
    if [ ! -d "$tree_path" ] || [ -L "$tree_path" ]; then
        return 0
    fi
    path_list=$TRANSACTION_DIR/fingerprint-paths.$$
    find "$tree_path" -mindepth 1 -print | LC_ALL=C sort > "$path_list" || return 1
    while IFS= read -r item; do
        relative=${item#"$tree_path"/}
        fingerprint_path "$item" "$label/$relative" || {
            rm -f "$path_list"
            return 1
        }
    done < "$path_list"
    rm -f "$path_list" || return 1
}

write_transaction_fingerprint() {
    local managed_path scope source_rel target_rel target_path
    local presence original_mode directory_path
    printf 'HEAD|%s\n' "$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || printf unknown)"
    printf '%s\n' 'GIT-STATUS-BEGIN'
    git -C "$ROOT" status --porcelain=v1 --untracked-files=all || return 1
    printf '%s\n' 'GIT-STATUS-END' 'GIT-INDEX-DIFF-BEGIN'
    git -C "$ROOT" diff --cached --binary --no-ext-diff || return 1
    printf '%s\n' 'GIT-INDEX-DIFF-END'

    for managed_path in $(transaction_repository_paths); do
        fingerprint_tree "$ROOT/$managed_path" "repository/$managed_path" || return 1
    done
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        target_path=$HOME/$target_rel
        fingerprint_path "$target_path" "home/$target_rel" || return 1
    done < "$MANIFEST"

    fingerprint_path "$ROOT_HINT" root-hint || return 1
    fingerprint_path "$DEVICE_CONFIG" device-config || return 1
    fingerprint_path "$CONFIG_DIR/generated.sh" generated-env || return 1
    fingerprint_path "$CONFIG_DIR/local.zsh" local-zsh || return 1
    fingerprint_path "$CONFIG_DIR/local.bash" local-bash || return 1
    fingerprint_path "$CONFIG_DIR/local.profile" local-profile || return 1
    fingerprint_path "$XDG_CONFIG_HOME/git/local.conf" git-local || return 1
    fingerprint_path "$HOME/.ssh/config.local" ssh-local || return 1
    fingerprint_path "$HOME/.bashrc" shell-bashrc || return 1
    fingerprint_path "$HOME/.bash_profile" shell-bash-profile || return 1
    fingerprint_path "$HOME/.profile" shell-profile || return 1
    fingerprint_path "$HOME/.zshrc" shell-zshrc || return 1
    fingerprint_path "$HOME/.zprofile" shell-zprofile || return 1
    fingerprint_tree "$XDG_STATE_HOME/dotfiles/copy-base" copy-base || return 1
    fingerprint_tree "$TRANSACTION_BACKUP_DIR" transaction-backup || return 1

    if [ -f "$TRANSACTION_DIR/dirs.list" ]; then
        while IFS='|' read -r presence original_mode directory_path; do
            [ -n "$directory_path" ] || continue
            fingerprint_path "$directory_path" "directory/$directory_path" || return 1
        done < "$TRANSACTION_DIR/dirs.list"
    fi
}

checkpoint_transaction_state() {
    local fingerprint_tmp marker_tmp local_head
    TRANSACTION_CHECKPOINT=$((TRANSACTION_CHECKPOINT + 1))
    TRANSACTION_EXPECTED_FILE=expected-$TRANSACTION_CHECKPOINT.fingerprint
    fingerprint_tmp=$TRANSACTION_DIR/$TRANSACTION_EXPECTED_FILE.tmp.$$
    write_transaction_fingerprint > "$fingerprint_tmp" \
        || die "cannot fingerprint transaction state"
    mv "$fingerprint_tmp" "$TRANSACTION_DIR/$TRANSACTION_EXPECTED_FILE" \
        || die "cannot activate transaction fingerprint"
    local_head=$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || printf unknown)
    marker_tmp=$TRANSACTION_DIR/ACTIVE.tmp.$$
    {
        printf 'status=active\n'
        printf 'local_head=%s\n' "$local_head"
        printf 'original_head=%s\n' "$TRANSACTION_ORIGINAL_HEAD"
        printf 'repository=%s\n' "$ROOT"
        printf 'backup_dir=%s\n' "$TRANSACTION_BACKUP_DIR"
        printf 'fingerprint=%s\n' "$TRANSACTION_EXPECTED_FILE"
    } > "$marker_tmp" || die "cannot write active transaction marker"
    mv "$marker_tmp" "$TRANSACTION_DIR/ACTIVE" \
        || die "cannot activate transaction checkpoint"
}

transaction_state_matches_checkpoint() {
    local current_fingerprint expected_path
    case "$TRANSACTION_EXPECTED_FILE" in
        */*) return 1 ;;
        expected-[0-9]*.fingerprint) ;;
        *) return 1 ;;
    esac
    expected_path=$TRANSACTION_DIR/$TRANSACTION_EXPECTED_FILE
    [ -f "$expected_path" ] || return 1
    current_fingerprint=$TRANSACTION_DIR/current-fingerprint.$$
    if ! write_transaction_fingerprint > "$current_fingerprint"; then
        rm -f "$current_fingerprint"
        return 1
    fi
    if cmp -s "$expected_path" "$current_fingerprint"; then
        rm -f "$current_fingerprint"
        return 0
    fi
    rm -f "$current_fingerprint"
    return 1
}

acquire_transaction_lock() {
    local allow_stale owner_pid
    allow_stale=${1:-0}
    mkdir -p "$(dirname "$TRANSACTION_LOCK")" || die "cannot create dotfiles state directory"
    if ! mkdir "$TRANSACTION_LOCK" 2>/dev/null; then
        owner_pid=$(sed -n 's/^pid=//p' "$TRANSACTION_LOCK/owner" 2>/dev/null || true)
        if [ -n "$owner_pid" ] && kill -0 "$owner_pid" 2>/dev/null; then
            die "another dotfiles transaction may be running (pid $owner_pid); lock: $TRANSACTION_LOCK"
        fi
        if [ "$allow_stale" -eq 1 ]; then
            rm -rf "$TRANSACTION_LOCK" || die "cannot remove stale transaction lock: $TRANSACTION_LOCK"
            mkdir "$TRANSACTION_LOCK" || die "cannot acquire transaction lock after stale recovery"
        else
            die "stale dotfiles transaction lock exists; run 'dotfiles recover': $TRANSACTION_LOCK"
        fi
    fi
    {
        printf 'pid=%s\n' "$$"
        printf 'repository=%s\n' "$ROOT"
    } > "$TRANSACTION_LOCK/owner" || {
        rmdir "$TRANSACTION_LOCK" 2>/dev/null || true
        die "cannot write transaction lock"
    }
    TRANSACTION_LOCK_HELD=1
    trap 'transaction_exit_handler $?' EXIT
    trap 'exit 130' HUP INT TERM
}

release_transaction_lock() {
    if [ "$TRANSACTION_LOCK_HELD" -eq 1 ]; then
        rm -rf "$TRANSACTION_LOCK" || warn "could not remove transaction lock: $TRANSACTION_LOCK"
        TRANSACTION_LOCK_HELD=0
    fi
}

snapshot_transaction_state_file() {
    local state_path state_name recorded_presence recorded_name recorded_path
    state_path=$1
    state_name=$2
    while IFS='|' read -r recorded_presence recorded_name recorded_path; do
        if [ "$recorded_name" = "$state_name" ]; then
            [ "$recorded_path" = "$state_path" ] \
                || die "transaction state name is already used for another path: $state_name"
            return 0
        fi
    done < "$TRANSACTION_DIR/state.list"
    if [ -e "$state_path" ] || [ -L "$state_path" ]; then
        printf 'P|%s|%s\n' "$state_name" "$state_path" >> "$TRANSACTION_DIR/state.list"
        cp -Pp "$state_path" "$TRANSACTION_DIR/state/$state_name" \
            || die "cannot snapshot transaction state: $state_path"
    else
        printf 'A|%s|%s\n' "$state_name" "$state_path" >> "$TRANSACTION_DIR/state.list"
    fi
}

snapshot_all_transaction_state_files() {
    snapshot_transaction_state_file "$ROOT_HINT" root-hint
    snapshot_transaction_state_file "$DEVICE_CONFIG" device-config
    snapshot_transaction_state_file "$CONFIG_DIR/generated.sh" generated-env
    snapshot_transaction_state_file "$CONFIG_DIR/local.zsh" local-zsh
    snapshot_transaction_state_file "$CONFIG_DIR/local.bash" local-bash
    snapshot_transaction_state_file "$CONFIG_DIR/local.profile" local-profile
    snapshot_transaction_state_file "$XDG_CONFIG_HOME/git/local.conf" git-local
    snapshot_transaction_state_file "$HOME/.ssh/config.local" ssh-local
    snapshot_transaction_state_file "$HOME/.bashrc" shell-bashrc
    snapshot_transaction_state_file "$HOME/.bash_profile" shell-bash-profile
    snapshot_transaction_state_file "$HOME/.profile" shell-profile
    snapshot_transaction_state_file "$HOME/.zshrc" shell-zshrc
    snapshot_transaction_state_file "$HOME/.zprofile" shell-zprofile
}

snapshot_transaction_directory() {
    local directory_path presence original_mode recorded_presence recorded_mode recorded_path
    directory_path=$1
    while IFS='|' read -r recorded_presence recorded_mode recorded_path; do
        [ "$recorded_path" = "$directory_path" ] && return 0
    done < "$TRANSACTION_DIR/dirs.list"

    if [ -d "$directory_path" ]; then
        presence=P
        original_mode=$(path_mode "$directory_path") \
            || die "cannot read directory mode for transaction: $directory_path"
    elif [ -e "$directory_path" ] || [ -L "$directory_path" ]; then
        presence=O
        original_mode=-
    else
        presence=A
        original_mode=-
    fi
    printf '%s|%s|%s\n' "$presence" "$original_mode" "$directory_path" \
        >> "$TRANSACTION_DIR/dirs.list" \
        || die "cannot snapshot transaction directory: $directory_path"
}

snapshot_transaction_directory_chain() {
    local directory_path boundary parent
    directory_path=$1
    boundary=$2
    [ "$directory_path" = "$boundary" ] && return 0
    case "$directory_path" in
        "$boundary"/*) ;;
        *) snapshot_transaction_directory "$directory_path"; return 0 ;;
    esac
    parent=$(dirname "$directory_path")
    [ "$parent" = "$directory_path" ] || \
        snapshot_transaction_directory_chain "$parent" "$boundary"
    snapshot_transaction_directory "$directory_path"
}

snapshot_transaction_directories() {
    local scope source_rel target_rel target_directory
    snapshot_transaction_directory_chain "$XDG_CONFIG_HOME" "$HOME"
    snapshot_transaction_directory_chain "$CONFIG_DIR" "$HOME"
    snapshot_transaction_directory_chain "$XDG_CONFIG_HOME/git" "$HOME"
    snapshot_transaction_directory_chain "$HOME/.ssh" "$HOME"
    snapshot_transaction_directory_chain "$HOME/.ssh/config.d" "$HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/bash" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/zsh" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/dotfiles/backups" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/vim" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/vim/backup" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/vim/swap" "$XDG_STATE_HOME"
    snapshot_transaction_directory_chain "$XDG_STATE_HOME/vim/undo" "$XDG_STATE_HOME"
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        target_directory=$(dirname "$HOME/$target_rel")
        snapshot_transaction_directory_chain "$target_directory" "$HOME"
    done < "$MANIFEST"
}

begin_transaction() {
    local transaction_base managed_path base_dir
    TRANSACTION_ORIGINAL_HEAD=$(git -C "$ROOT" rev-parse --verify HEAD 2>/dev/null) \
        || die "transaction requires a repository with at least one commit"
    transaction_base=$XDG_STATE_HOME/dotfiles/transactions
    TRANSACTION_DIR=$transaction_base/$(date +%Y%m%d-%H%M%S)-$$
    TRANSACTION_BACKUP_DIR=$XDG_STATE_HOME/dotfiles/backups/transaction-$(basename "$TRANSACTION_DIR")
    TRANSACTION_BUILDING=1
    mkdir -p "$TRANSACTION_DIR/repository" "$TRANSACTION_DIR/state" \
        || die "cannot create transaction snapshot: $TRANSACTION_DIR"
    chmod 700 "$TRANSACTION_DIR" 2>/dev/null || true

    for managed_path in $(transaction_repository_paths); do
        if [ -e "$ROOT/$managed_path" ] || [ -L "$ROOT/$managed_path" ]; then
            mkdir -p "$(dirname "$TRANSACTION_DIR/repository/$managed_path")" \
                || die "cannot prepare repository snapshot"
            cp -Rp "$ROOT/$managed_path" "$TRANSACTION_DIR/repository/$managed_path" \
                || die "cannot snapshot repository path: $managed_path"
        fi
    done

    : > "$TRANSACTION_DIR/state.list"
    : > "$TRANSACTION_DIR/dirs.list"
    snapshot_all_transaction_state_files

    base_dir=$XDG_STATE_HOME/dotfiles/copy-base
    if [ -e "$base_dir" ]; then
        printf 'P\n' > "$TRANSACTION_DIR/copy-base.status"
        cp -Rp "$base_dir" "$TRANSACTION_DIR/copy-base" \
            || die "cannot snapshot copy baselines"
    else
        printf 'A\n' > "$TRANSACTION_DIR/copy-base.status"
    fi

    TRANSACTION_HOME_LIST=$TRANSACTION_DIR/home.list
    snapshot_transaction_directories
    checkpoint_transaction_state
    TRANSACTION_BUILDING=0
    TRANSACTION_ACTIVE=1
}

snapshot_transaction_home() {
    local scope source_rel target_rel target_path snapshot_path
    mkdir -p "$TRANSACTION_DIR/home" || die "cannot prepare HOME snapshot"
    : > "$TRANSACTION_HOME_LIST"
    while IFS='|' read -r scope source_rel target_rel; do
        case "$scope" in ""|\#*) continue ;; esac
        scope_applies "$scope" || continue
        validate_relative_path "$target_rel"
        target_path=$HOME/$target_rel
        snapshot_path=$TRANSACTION_DIR/home/$target_rel
        if [ -e "$target_path" ] || [ -L "$target_path" ]; then
            printf 'P|%s\n' "$target_rel" >> "$TRANSACTION_HOME_LIST"
            mkdir -p "$(dirname "$snapshot_path")" || die "cannot prepare HOME snapshot path"
            cp -Rp "$target_path" "$snapshot_path" || die "cannot snapshot HOME target: $target_rel"
        else
            printf 'A|%s\n' "$target_rel" >> "$TRANSACTION_HOME_LIST"
        fi
    done < "$MANIFEST"
}

restore_transaction_repository() {
    local managed_path failed
    failed=0
    git -C "$ROOT" rebase --abort >/dev/null 2>&1 || true
    if ! git -C "$ROOT" reset --hard "$TRANSACTION_ORIGINAL_HEAD" >/dev/null 2>&1; then
        warn "could not reset Git HEAD to $TRANSACTION_ORIGINAL_HEAD"
        return 1
    fi
    for managed_path in $(transaction_repository_paths); do
        if [ -e "$ROOT/$managed_path" ] || [ -L "$ROOT/$managed_path" ]; then
            rm -rf "$ROOT/$managed_path" || failed=1
        fi
        if [ -e "$TRANSACTION_DIR/repository/$managed_path" ] || \
           [ -L "$TRANSACTION_DIR/repository/$managed_path" ]; then
            mkdir -p "$(dirname "$ROOT/$managed_path")" || failed=1
            cp -Rp "$TRANSACTION_DIR/repository/$managed_path" "$ROOT/$managed_path" || failed=1
        fi
    done
    return "$failed"
}

restore_transaction_home() {
    local presence target_rel target_path snapshot_path failed
    failed=0
    [ -f "$TRANSACTION_HOME_LIST" ] || return 0
    while IFS='|' read -r presence target_rel; do
        [ -n "$target_rel" ] || continue
        validate_relative_path "$target_rel"
        target_path=$HOME/$target_rel
        snapshot_path=$TRANSACTION_DIR/home/$target_rel
        if [ -e "$target_path" ] || [ -L "$target_path" ]; then
            rm -rf "$target_path" || failed=1
        fi
        if [ "$presence" = P ]; then
            mkdir -p "$(dirname "$target_path")" || failed=1
            cp -Rp "$snapshot_path" "$target_path" || failed=1
        fi
    done < "$TRANSACTION_HOME_LIST"
    return "$failed"
}

restore_transaction_state() {
    local presence state_name state_path snapshot_path base_dir base_status failed
    failed=0
    if [ -f "$TRANSACTION_DIR/state.list" ]; then
        while IFS='|' read -r presence state_name state_path; do
            [ -n "$state_path" ] || continue
            snapshot_path=$TRANSACTION_DIR/state/$state_name
            if [ -e "$state_path" ] || [ -L "$state_path" ]; then
                rm -f "$state_path" || failed=1
            fi
            if [ "$presence" = P ]; then
                mkdir -p "$(dirname "$state_path")" || failed=1
                cp -Pp "$snapshot_path" "$state_path" || failed=1
            fi
        done < "$TRANSACTION_DIR/state.list"
    fi

    base_dir=$XDG_STATE_HOME/dotfiles/copy-base
    base_status=$(sed -n '1p' "$TRANSACTION_DIR/copy-base.status" 2>/dev/null || printf A)
    if [ -e "$base_dir" ]; then
        rm -rf "$base_dir" || failed=1
    fi
    if [ "$base_status" = P ]; then
        mkdir -p "$(dirname "$base_dir")" || failed=1
        cp -Rp "$TRANSACTION_DIR/copy-base" "$base_dir" || failed=1
    fi
    return "$failed"
}

restore_transaction_directories() {
    local reversed_list presence original_mode directory_path failed
    failed=0
    [ -f "$TRANSACTION_DIR/dirs.list" ] || return 0
    reversed_list=$TRANSACTION_DIR/dirs-reversed.$$
    awk '{ line[NR]=$0 } END { for (i=NR; i>=1; i--) print line[i] }' \
        "$TRANSACTION_DIR/dirs.list" > "$reversed_list" || return 1
    while IFS='|' read -r presence original_mode directory_path; do
        [ -n "$directory_path" ] || continue
        case "$presence" in
            P)
                if [ ! -d "$directory_path" ]; then
                    if [ -e "$directory_path" ] || [ -L "$directory_path" ]; then
                        warn "cannot restore directory replaced by another path: $directory_path"
                        failed=1
                        continue
                    fi
                    mkdir -p "$directory_path" || {
                        failed=1
                        continue
                    }
                fi
                chmod "$original_mode" "$directory_path" 2>/dev/null || failed=1
                ;;
            A)
                if [ -d "$directory_path" ] && [ ! -L "$directory_path" ]; then
                    if ! rmdir "$directory_path" 2>/dev/null; then
                        warn "preserved non-empty directory created during transaction: $directory_path"
                        failed=1
                    fi
                elif [ -e "$directory_path" ] || [ -L "$directory_path" ]; then
                    warn "preserved unexpected path created during transaction: $directory_path"
                    failed=1
                fi
                ;;
            O) ;;
            *) failed=1 ;;
        esac
    done < "$reversed_list"
    rm -f "$reversed_list" || failed=1
    return "$failed"
}

rollback_transaction() {
    local failed
    TRANSACTION_ACTIVE=0
    failed=0
    warn "dotfiles transaction failed; restoring repository and HOME"
    restore_transaction_repository || failed=1
    restore_transaction_home || failed=1
    restore_transaction_state || failed=1
    if [ -n "$BACKUP_DIR" ]; then
        case "$BACKUP_DIR" in
            "$XDG_STATE_HOME/dotfiles/backups/"*) rm -rf "$BACKUP_DIR" || failed=1 ;;
            *) warn "refusing to remove unexpected backup path: $BACKUP_DIR"; failed=1 ;;
        esac
    fi
    restore_transaction_directories || failed=1
    if [ "$failed" -eq 0 ]; then
        rm -rf "$TRANSACTION_DIR" || failed=1
    fi
    if [ "$failed" -eq 0 ]; then
        warn "rollback completed successfully"
        return 0
    fi
    warn "rollback was incomplete; recovery snapshot retained at $TRANSACTION_DIR"
    return 1
}

transaction_exit_handler() {
    local exit_status
    exit_status=$1
    trap - EXIT HUP INT TERM
    if [ "$TRANSACTION_COMMITTED" -eq 1 ]; then
        rm -rf "$TRANSACTION_DIR" || exit_status=1
    elif [ "$TRANSACTION_ACTIVE" -eq 1 ]; then
        if [ "$TRANSACTION_PUSHING" -eq 1 ]; then
            leave_transaction_in_doubt
        else
            rollback_transaction || exit_status=1
        fi
    elif [ "$TRANSACTION_BUILDING" -eq 1 ] && [ -n "$TRANSACTION_DIR" ]; then
        rm -rf "$TRANSACTION_DIR" || exit_status=1
    fi
    release_transaction_lock
    exit "$exit_status"
}

finish_transaction() {
    TRANSACTION_COMMITTED=1
    TRANSACTION_ACTIVE=0
    {
        printf 'status=committed\n'
        printf 'repository=%s\n' "$ROOT"
    } > "$TRANSACTION_DIR/COMMITTED" 2>/dev/null || true
    rm -f "$TRANSACTION_DIR/ACTIVE" "$TRANSACTION_DIR/IN_DOUBT" 2>/dev/null || true
    trap - EXIT HUP INT TERM
    if ! rm -rf "$TRANSACTION_DIR"; then
        warn "transaction succeeded but snapshot cleanup failed: $TRANSACTION_DIR"
    fi
    release_transaction_lock
}

mark_transaction_in_doubt() {
    local local_head marker_tmp
    [ -n "$TRANSACTION_EXPECTED_FILE" ] \
        || die "cannot mark a transaction in doubt without a verified checkpoint"
    local_head=$(git -C "$ROOT" rev-parse HEAD 2>/dev/null || printf unknown)
    marker_tmp=$TRANSACTION_DIR/IN_DOUBT.tmp.$$
    {
        printf 'status=in-doubt\n'
        printf 'local_head=%s\n' "$local_head"
        printf 'remote=%s\n' "$SYNC_REMOTE"
        printf 'remote_ref=%s\n' "$SYNC_MERGE_REF"
        printf 'original_head=%s\n' "$TRANSACTION_ORIGINAL_HEAD"
        printf 'repository=%s\n' "$ROOT"
        printf 'backup_dir=%s\n' "$TRANSACTION_BACKUP_DIR"
        printf 'fingerprint=%s\n' "$TRANSACTION_EXPECTED_FILE"
    } > "$marker_tmp" || die "cannot write uncertain transaction marker"
    mv "$marker_tmp" "$TRANSACTION_DIR/IN_DOUBT" \
        || die "cannot activate uncertain transaction marker"
    rm -f "$TRANSACTION_DIR/ACTIVE" || true
}

leave_transaction_in_doubt() {
    mark_transaction_in_doubt
    TRANSACTION_ACTIVE=0
    trap - EXIT HUP INT TERM
    warn "push failed and the remote state could not be confirmed; automatic rollback would be unsafe"
    warn "the committed/deployed local state and recovery snapshot were retained"
    warn "transaction snapshot: $TRANSACTION_DIR"
    warn "verify with: git ls-remote $SYNC_REMOTE $SYNC_MERGE_REF"
    warn "save, sync, and update remain blocked until recovery completes"
    # Keep a stale lock as a durable guard. recover is the only command allowed
    # to replace it after this process exits.
    {
        printf 'status=in-doubt\n'
        printf 'repository=%s\n' "$ROOT"
        printf 'transaction=%s\n' "$TRANSACTION_DIR"
    } > "$TRANSACTION_LOCK/owner" 2>/dev/null \
        || warn "could not mark the transaction lock as unresolved"
    TRANSACTION_LOCK_HELD=0
}

recover_transaction() {
    local requested_dir transaction_base candidate marker_file marker_status
    local recorded_root local_head remote_head candidate_count relative_candidate expected_backup_dir
    requested_dir=${1:-}
    acquire_transaction_lock 1
    transaction_base=$XDG_STATE_HOME/dotfiles/transactions
    if [ -n "$requested_dir" ]; then
        TRANSACTION_DIR=$requested_dir
        case "$TRANSACTION_DIR" in
            "$transaction_base"/*)
                relative_candidate=${TRANSACTION_DIR#"$transaction_base"/}
                case "$relative_candidate" in */*) die "transaction path must be a direct child of $transaction_base" ;; esac
                ;;
            *) die "transaction path must be inside $transaction_base" ;;
        esac
    else
        TRANSACTION_DIR=""
        candidate_count=0
        for candidate in "$transaction_base"/*; do
            if [ ! -f "$candidate/IN_DOUBT" ] && [ ! -f "$candidate/ACTIVE" ]; then
                continue
            fi
            TRANSACTION_DIR=$candidate
            candidate_count=$((candidate_count + 1))
        done
        [ "$candidate_count" -le 1 ] \
            || die "multiple recoverable transactions exist; specify one transaction directory explicitly"
    fi
    [ -n "$TRANSACTION_DIR" ] || die "no recoverable dotfiles transaction was found"
    if [ -f "$TRANSACTION_DIR/IN_DOUBT" ]; then
        marker_file=$TRANSACTION_DIR/IN_DOUBT
    elif [ -f "$TRANSACTION_DIR/ACTIVE" ]; then
        marker_file=$TRANSACTION_DIR/ACTIVE
    else
        die "not a recoverable transaction: $TRANSACTION_DIR"
    fi
    marker_status=$(sed -n 's/^status=//p' "$marker_file")

    local_head=$(sed -n 's/^local_head=//p' "$marker_file")
    SYNC_REMOTE=$(sed -n 's/^remote=//p' "$marker_file")
    SYNC_MERGE_REF=$(sed -n 's/^remote_ref=//p' "$marker_file")
    TRANSACTION_ORIGINAL_HEAD=$(sed -n 's/^original_head=//p' "$marker_file")
    recorded_root=$(sed -n 's/^repository=//p' "$marker_file")
    TRANSACTION_BACKUP_DIR=$(sed -n 's/^backup_dir=//p' "$marker_file")
    TRANSACTION_EXPECTED_FILE=$(sed -n 's/^fingerprint=//p' "$marker_file")
    BACKUP_DIR=$TRANSACTION_BACKUP_DIR
    TRANSACTION_HOME_LIST=$TRANSACTION_DIR/home.list

    [ "$recorded_root" = "$ROOT" ] || die "transaction belongs to another repository: $recorded_root"
    expected_backup_dir=$XDG_STATE_HOME/dotfiles/backups/transaction-$(basename "$TRANSACTION_DIR")
    [ "$TRANSACTION_BACKUP_DIR" = "$expected_backup_dir" ] \
        || die "transaction contains an invalid backup path: $TRANSACTION_BACKUP_DIR"
    if [ "$marker_status" = active ]; then
        transaction_state_matches_checkpoint \
            || die "managed state changed after the interruption; refusing automatic rollback: $TRANSACTION_DIR"
        rollback_transaction || die "interrupted transaction rollback was incomplete"
        log "Interrupted local transaction was rolled back."
        release_transaction_lock
        trap - EXIT HUP INT TERM
        return
    fi
    [ "$marker_status" = in-doubt ] || die "unknown transaction marker status: $marker_status"
    [ -n "$local_head" ] && git -C "$ROOT" cat-file -e "$local_head^{commit}" 2>/dev/null \
        || die "recorded transaction commit is not available locally: $local_head"
    if ! git -C "$ROOT" fetch "$SYNC_REMOTE" "$SYNC_MERGE_REF" >/dev/null 2>&1; then
        die "remote is still unreachable; transaction remains in doubt at $TRANSACTION_DIR"
    fi
    remote_head=$(git -C "$ROOT" rev-parse FETCH_HEAD 2>/dev/null || true)
    [ -n "$remote_head" ] || die "cannot resolve the remote branch; transaction remains in doubt"

    if [ "$remote_head" = "$local_head" ] || \
       git -C "$ROOT" merge-base --is-ancestor "$local_head" "$remote_head"; then
        rm -rf "$TRANSACTION_DIR" || die "remote committed, but snapshot cleanup failed: $TRANSACTION_DIR"
        log "Remote contains the transaction commit; local state was kept and recovery is complete."
    else
        transaction_state_matches_checkpoint \
            || die "remote lacks the commit, but managed state changed after the uncertain push; refusing automatic rollback: $TRANSACTION_DIR"
        rollback_transaction || die "automatic recovery rollback was incomplete"
        log "Remote does not contain the transaction commit; local state was rolled back."
    fi
    release_transaction_lock
    trap - EXIT HUP INT TERM
}

prepare_remote_sync() {
    local branch_name
    branch_name=$(git -C "$ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null) \
        || die "the operation requires a checked-out branch"
    SYNC_REMOTE=$(git -C "$ROOT" config --get "branch.$branch_name.remote" 2>/dev/null || true)
    SYNC_MERGE_REF=$(git -C "$ROOT" config --get "branch.$branch_name.merge" 2>/dev/null || true)
    [ -n "$SYNC_REMOTE" ] && [ "$SYNC_REMOTE" != . ] \
        || die "the operation requires an upstream remote; configure it with git push -u"
    [ -n "$SYNC_MERGE_REF" ] || die "the operation requires an upstream branch; configure it with git push -u"
    git -C "$ROOT" fetch "$SYNC_REMOTE" || die "git fetch failed before transaction; nothing was changed locally"
    SYNC_UPSTREAM_REF=$(git -C "$ROOT" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null || true)
    [ -n "$SYNC_UPSTREAM_REF" ] || die "cannot resolve the configured upstream branch"
}

save_repository() {
    local mode message push_changes committed new_head remote_head push_confirmed
    mode=$1
    message=$2
    push_changes=$3
    committed=0
    push_confirmed=0

    command -v git >/dev/null 2>&1 || die "git is required for save"
    git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "$ROOT is not a Git worktree"
    git -C "$ROOT" diff --cached --quiet || die "repository already has staged changes; commit or unstage them first"
    acquire_transaction_lock
    assert_no_pending_transaction
    check_repository_scope
    if [ "$push_changes" -eq 1 ]; then
        prepare_remote_sync
    fi
    begin_transaction

    if [ "$mode" = copy ]; then
        capture_copy_changes
        checkpoint_transaction_state
    fi

    git -C "$ROOT" add -A -- \
        .dotfiles-manifest .gitattributes .gitignore README.md \
        bin dotfiles examples profiles tests || die "git add failed"
    checkpoint_transaction_state

    if ! git -C "$ROOT" diff --cached --quiet; then
        git -C "$ROOT" diff --cached --check || die "staged changes contain whitespace errors"
        check_staged_secrets
        if [ -z "$message" ]; then
            message="dotfiles: update $(date '+%Y-%m-%d %H:%M')"
        fi
        git -C "$ROOT" commit -m "$message" || die "git commit failed; staged changes were kept"
        committed=1
        log "Created dotfiles commit."
    else
        log "No dotfiles changes to commit."
    fi
    checkpoint_transaction_state

    git -C "$ROOT" diff --quiet || die "transaction produced unexpected unstaged changes"
    if [ -n "$(git -C "$ROOT" ls-files --others --exclude-standard)" ]; then
        die "transaction produced unexpected untracked files"
    fi

    if [ "$push_changes" -eq 1 ]; then
        git -C "$ROOT" rebase "$SYNC_UPSTREAM_REF" \
            || die "git rebase failed; the transaction will be rolled back"
        checkpoint_transaction_state
    fi

    snapshot_transaction_directories
    snapshot_transaction_home
    install_all "$mode"
    checkpoint_transaction_state

    if [ "$push_changes" -eq 1 ]; then
        new_head=$(git -C "$ROOT" rev-parse HEAD) || die "cannot resolve transaction commit"
        mark_transaction_in_doubt
        TRANSACTION_PUSHING=1
        if git -C "$ROOT" push "$SYNC_REMOTE" "HEAD:$SYNC_MERGE_REF"; then
            push_confirmed=1
        else
            if git -C "$ROOT" fetch "$SYNC_REMOTE" "$SYNC_MERGE_REF" >/dev/null 2>&1; then
                remote_head=$(git -C "$ROOT" rev-parse FETCH_HEAD 2>/dev/null || true)
                if [ -n "$remote_head" ] && \
                   { [ "$remote_head" = "$new_head" ] || \
                     git -C "$ROOT" merge-base --is-ancestor "$new_head" "$remote_head"; }; then
                    warn "push reported an error, but the remote contains the transaction commit"
                    push_confirmed=1
                fi
            else
                leave_transaction_in_doubt
                return 2
            fi
        fi
        TRANSACTION_PUSHING=0
        [ "$push_confirmed" -eq 1 ] \
            || die "git push failed and the remote did not confirm the transaction commit"
    fi

    finish_transaction
    if [ "$push_changes" -eq 1 ]; then
        log "Updated from remote, committed, deployed, and pushed successfully."
    elif [ "$committed" -eq 1 ]; then
        log "Commit is local. Run 'dotfiles sync' next time to push automatically."
    fi
}

write_device_config() {
    local tmp
    mkdir -p "$CONFIG_DIR" || die "cannot create $CONFIG_DIR"
    tmp=$DEVICE_CONFIG.tmp.$$
    if ! {
        printf '# Local device settings; never add this file to the dotfiles repository.\n'
        printf 'DOTFILES_INSTALL_MODE=%s\n' "$(shell_quote "$DOTFILES_INSTALL_MODE")"
        if [ -n "$DOTFILES_DEVICE_CONDA_ROOT" ]; then
            printf 'DOTFILES_DEVICE_CONDA_ROOT=%s\n' "$(shell_quote "$DOTFILES_DEVICE_CONDA_ROOT")"
        else
            printf 'DOTFILES_DEVICE_CONDA_ROOT=\n'
        fi
    } > "$tmp"; then
        rm -f "$tmp"
        die "cannot write $tmp"
    fi
    chmod 600 "$tmp" 2>/dev/null || true
    if ! mv "$tmp" "$DEVICE_CONFIG"; then
        rm -f "$tmp"
        die "cannot install $DEVICE_CONFIG"
    fi
    log "updated: $DEVICE_CONFIG"
}

config_command() {
    local action key value
    action=${1:-list}
    case "$action" in
        list)
            printf 'install-mode=%s\n' "$DOTFILES_INSTALL_MODE"
            printf 'conda-root=%s\n' "$DOTFILES_DEVICE_CONDA_ROOT"
            ;;
        set)
            key=${2:-}
            value=${3:-}
            [ -n "$key" ] || die "usage: $PROGRAM config set <install-mode|conda-root> VALUE"
            case "$key" in
                install-mode)
                    case "$value" in auto|link|copy) ;; *) die "install-mode must be auto, link, or copy" ;; esac
                    DOTFILES_INSTALL_MODE=$value
                    ;;
                conda-root)
                    [ -n "$value" ] || die "conda-root requires a path"
                    DOTFILES_DEVICE_CONDA_ROOT=$value
                    ;;
                *) die "unknown setting: $key" ;;
            esac
            acquire_transaction_lock
            assert_no_pending_transaction
            preflight_local_transaction
            begin_transaction
            snapshot_transaction_directories
            write_device_config
            write_generated_env
            checkpoint_transaction_state
            finish_transaction
            ;;
        unset)
            key=${2:-}
            case "$key" in
                conda-root) DOTFILES_DEVICE_CONDA_ROOT="" ;;
                install-mode) DOTFILES_INSTALL_MODE=auto ;;
                *) die "unknown setting: $key" ;;
            esac
            acquire_transaction_lock
            assert_no_pending_transaction
            preflight_local_transaction
            begin_transaction
            snapshot_transaction_directories
            write_device_config
            write_generated_env
            checkpoint_transaction_state
            finish_transaction
            ;;
        *) die "usage: $PROGRAM config [list|set|unset]" ;;
    esac
}

doctor() {
    local failures command_name private_file
    failures=0
    log "Repository : $ROOT"
    log "Platform   : $OS"
    log "Host       : $HOST_NAME"
    log "Home       : $HOME"
    log "Mode       : $(resolved_mode)"
    if [ -n "$(detect_conda 2>/dev/null || true)" ]; then
        log "Conda      : $(detect_conda 2>/dev/null)"
    else
        log "Conda      : not found (optional)"
    fi
    for command_name in bash git; do
        if command -v "$command_name" >/dev/null 2>&1; then
            printf '[ok]      command: %s\n' "$command_name"
        else
            printf '[required] command not found: %s\n' "$command_name"
            failures=$((failures + 1))
        fi
    done
    for command_name in ssh vim; do
        if command -v "$command_name" >/dev/null 2>&1; then
            printf '[ok]      command: %s\n' "$command_name"
        else
            printf '[optional] command not found: %s\n' "$command_name"
        fi
    done
    if command -v zsh >/dev/null 2>&1; then
        printf '[ok]      command: zsh\n'
    else
        printf '[optional] command not found: zsh\n'
    fi
    private_file=$(find "$ROOT" -path "$ROOT/.git" -prune -o -type f \
        \( -name 'id_rsa*' -o -name 'id_dsa*' -o -name 'id_ecdsa*' \
        -o -name 'id_ed25519*' -o -name '*.pem' -o -name '*.key' \) \
        -print 2>/dev/null | sed -n '1p')
    if [ -n "$private_file" ]; then
        warn "possible private key inside repository: $private_file"
        failures=$((failures + 1))
    else
        printf '[ok]      no obvious private-key files in repository\n'
    fi
    return "$failures"
}

resume_update_deployment() {
    local requested_dir mode transaction_base relative_dir marker_file
    local recorded_root expected_backup owner_pid checkpoint_number
    requested_dir=$1
    mode=$(resolved_mode "$2")
    transaction_base=$XDG_STATE_HOME/dotfiles/transactions

    [ -n "${DOTFILES_RESUME_TRANSACTION:-}" ] \
        && [ "$DOTFILES_RESUME_TRANSACTION" = "$requested_dir" ] \
        || die "internal update deployment requires its parent transaction"
    case "$requested_dir" in
        "$transaction_base"/*)
            relative_dir=${requested_dir#"$transaction_base"/}
            case "$relative_dir" in ""|*/*) die "invalid update transaction path: $requested_dir" ;; esac
            ;;
        *) die "update transaction is outside the state directory: $requested_dir" ;;
    esac

    marker_file=$requested_dir/ACTIVE
    [ -f "$marker_file" ] || die "update transaction is not active: $requested_dir"
    recorded_root=$(sed -n 's/^repository=//p' "$marker_file")
    [ "$recorded_root" = "$ROOT" ] \
        || die "update transaction belongs to another repository: $recorded_root"
    owner_pid=$(sed -n 's/^pid=//p' "$TRANSACTION_LOCK/owner" 2>/dev/null || true)
    [ -n "$owner_pid" ] && [ "$owner_pid" = "$PPID" ] \
        || die "internal update deployment is not owned by its parent process"

    TRANSACTION_DIR=$requested_dir
    TRANSACTION_ORIGINAL_HEAD=$(sed -n 's/^original_head=//p' "$marker_file")
    TRANSACTION_BACKUP_DIR=$(sed -n 's/^backup_dir=//p' "$marker_file")
    TRANSACTION_EXPECTED_FILE=$(sed -n 's/^fingerprint=//p' "$marker_file")
    expected_backup=$XDG_STATE_HOME/dotfiles/backups/transaction-$(basename "$TRANSACTION_DIR")
    [ "$TRANSACTION_BACKUP_DIR" = "$expected_backup" ] \
        || die "update transaction contains an invalid backup path"
    case "$TRANSACTION_EXPECTED_FILE" in
        expected-[0-9]*.fingerprint)
            checkpoint_number=${TRANSACTION_EXPECTED_FILE#expected-}
            checkpoint_number=${checkpoint_number%.fingerprint}
            case "$checkpoint_number" in ""|*[!0-9]*) die "invalid update checkpoint" ;; esac
            TRANSACTION_CHECKPOINT=$checkpoint_number
            ;;
        *) die "invalid update transaction fingerprint" ;;
    esac

    BACKUP_DIR=$TRANSACTION_BACKUP_DIR
    TRANSACTION_HOME_LIST=$TRANSACTION_DIR/home.list
    TRANSACTION_ACTIVE=1
    snapshot_all_transaction_state_files
    snapshot_transaction_directories
    snapshot_transaction_home
    checkpoint_transaction_state
    install_all "$mode"
    checkpoint_transaction_state
    TRANSACTION_ACTIVE=0
}

update_repository() {
    local mode
    command -v git >/dev/null 2>&1 || die "git is required for update"
    git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "$ROOT is not a Git worktree"
    acquire_transaction_lock
    assert_no_pending_transaction
    if [ -n "$(git -C "$ROOT" status --porcelain)" ]; then
        die "repository has uncommitted changes; commit or stash them before update"
    fi
    mode=$(resolved_mode)
    prepare_remote_sync
    begin_transaction
    git -C "$ROOT" merge --ff-only "$SYNC_UPSTREAM_REF" \
        || die "fast-forward update failed; the transaction will be rolled back"
    checkpoint_transaction_state
    DOTFILES_RESUME_TRANSACTION=$TRANSACTION_DIR \
        "$ROOT/bin/dotfiles" __resume-update "$TRANSACTION_DIR" "$mode" \
        || die "updated dotfiles manager could not deploy; the transaction will be rolled back"
    finish_transaction
    log "Fast-forwarded and deployed successfully."
}

transactional_install() {
    local mode
    mode=$1
    acquire_transaction_lock
    assert_no_pending_transaction
    preflight_local_transaction
    begin_transaction
    snapshot_transaction_directories
    snapshot_transaction_home
    install_all "$mode"
    checkpoint_transaction_state
    finish_transaction
}

transactional_uninstall() {
    local mode
    mode=$1
    acquire_transaction_lock
    assert_no_pending_transaction
    preflight_local_transaction
    begin_transaction
    snapshot_transaction_directories
    snapshot_transaction_home
    uninstall_all "$mode"
    checkpoint_transaction_state
    finish_transaction
}

usage() {
    cat <<EOF
Usage: $PROGRAM COMMAND [OPTIONS]

Commands:
  install [--mode auto|link|copy] [--dry-run]
                                  Install or reconcile all managed files
  status [--mode auto|link|copy]  Report missing or changed files
  uninstall [--mode ...] [--dry-run]
                                  Remove only unchanged managed files
  config [list]                   Show device-local settings
  config set install-mode MODE    Persist auto, link, or copy
  config set conda-root PATH      Persist this device's Conda root
  config unset KEY                Reset a device setting
  doctor                          Check platform, tools, and secret hygiene
  update                          Transactionally fast-forward and reinstall
  save|commit [-m MESSAGE] [--mode ...] [--push]
                                  Transactionally capture, commit, and install
  sync|publish [-m MESSAGE] [--mode ...]
                                  Fetch, save, rebase, install, and push
  recover [TRANSACTION_DIR]       Recover an interrupted or uncertain transaction
  root                            Print the active repository path
  help                            Show this help

Examples:
  ./bin/dotfiles install --dry-run
  ./bin/dotfiles install
  dotfiles config set conda-root "\$HOME/miniconda3"
  dotfiles status
  dotfiles save -m "update vim settings"
  dotfiles sync -m "sync dotfiles"
EOF
}

parse_mode_and_dry_run() {
    PARSED_MODE=""
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --mode)
                [ "$#" -ge 2 ] || die "--mode requires a value"
                PARSED_MODE=$2
                shift 2
                ;;
            --mode=*) PARSED_MODE=${1#--mode=}; shift ;;
            --dry-run|-n) DRY_RUN=1; shift ;;
            *) die "unknown option: $1" ;;
        esac
    done
    PARSED_MODE=$(resolved_mode "$PARSED_MODE")
}

parse_save_options() {
    SAVE_MODE=""
    SAVE_MESSAGE=""
    SAVE_PUSH=${1:-0}
    if [ "$#" -gt 0 ]; then shift; fi
    while [ "$#" -gt 0 ]; do
        case "$1" in
            --mode)
                [ "$#" -ge 2 ] || die "--mode requires a value"
                SAVE_MODE=$2
                shift 2
                ;;
            --mode=*) SAVE_MODE=${1#--mode=}; shift ;;
            -m|--message)
                [ "$#" -ge 2 ] || die "$1 requires a value"
                SAVE_MESSAGE=$2
                shift 2
                ;;
            --message=*) SAVE_MESSAGE=${1#--message=}; shift ;;
            --push) SAVE_PUSH=1; shift ;;
            --)
                shift
                [ "$#" -gt 0 ] || die "-- must be followed by a commit message"
                [ -z "$SAVE_MESSAGE" ] || die "commit message was provided more than once"
                SAVE_MESSAGE=$1
                shift
                [ "$#" -eq 0 ] || die "unexpected arguments after commit message"
                ;;
            -*) die "unknown option: $1" ;;
            *)
                [ -z "$SAVE_MESSAGE" ] || die "commit message was provided more than once"
                SAVE_MESSAGE=$1
                shift
                ;;
        esac
    done
    SAVE_MODE=$(resolved_mode "$SAVE_MODE")
}

COMMAND=${1:-help}
if [ "$#" -gt 0 ]; then shift; fi
case "$COMMAND" in
    install|apply)
        parse_mode_and_dry_run "$@"
        if [ "$DRY_RUN" -eq 1 ]; then
            install_all "$PARSED_MODE"
        else
            transactional_install "$PARSED_MODE"
        fi
        ;;
    status)
        parse_mode_and_dry_run "$@"
        status_all "$PARSED_MODE"
        ;;
    uninstall|unlink)
        parse_mode_and_dry_run "$@"
        if [ "$DRY_RUN" -eq 1 ]; then
            uninstall_all "$PARSED_MODE"
        else
            transactional_uninstall "$PARSED_MODE"
        fi
        ;;
    config) config_command "$@" ;;
    doctor) doctor ;;
    update) update_repository ;;
    save|commit)
        parse_save_options 0 "$@"
        save_repository "$SAVE_MODE" "$SAVE_MESSAGE" "$SAVE_PUSH"
        ;;
    publish|sync)
        parse_save_options 1 "$@"
        save_repository "$SAVE_MODE" "$SAVE_MESSAGE" "$SAVE_PUSH"
        ;;
    recover)
        [ "$#" -le 1 ] || die "usage: $PROGRAM recover [TRANSACTION_DIR]"
        recover_transaction "${1:-}"
        ;;
    __resume-update)
        [ "$#" -eq 2 ] || die "invalid internal update deployment arguments"
        resume_update_deployment "$1" "$2"
        ;;
    root) printf '%s\n' "$ROOT" ;;
    help|-h|--help) usage ;;
    *) usage >&2; die "unknown command: $COMMAND" ;;
esac
